# ─── Application ───────────────────────────────────────────────
APP_NAME="AI Developer Assistant"
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ─── Security ──────────────────────────────────────────────────
# Allowed client API keys (JSON list). Leave empty to disable auth for local dev.
# In production, set at least one key; requests must send it as the X-API-Key header.
API_KEYS=[]
# Fixed-window request cap per client, per minute. Set 0 to disable rate limiting.
RATE_LIMIT_PER_MINUTE=60

# ─── Database (PostgreSQL) ─────────────────────────────────────
POSTGRES_USER=devassist
POSTGRES_PASSWORD=devassist
POSTGRES_DB=devassist
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full async URL (overrides the parts above if set)
# DATABASE_URL=postgresql+asyncpg://devassist:devassist@localhost:5432/devassist

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── RAG / Embeddings ──────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
VECTOR_STORE=faiss                 # faiss | chroma
VECTOR_STORE_PATH=./data/vectorstore
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=20
RERANK_TOP_K=6

# ─── LLM provider ──────────────────────────────────────────────
LLM_PROVIDER=openai                # openai | anthropic | gemini | deepseek | qwen
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# ─── GitHub ingestion ──────────────────────────────────────────
GITHUB_TOKEN=                      # optional, raises rate limits for repo indexing
